# Copy this file to .env.local for local development.
# In production these are set in Vercel → Project → Settings → Environment Variables.
# Nothing in this file is a real secret — replace every value before use.

# --- Database (Neon Postgres) ---------------------------------------------
# Connection string for the Neon serverless Postgres database. lib/db.ts falls
# back to POSTGRES_URL then DATABASE_URL_UNPOOLED if this isn't set.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# --- NextAuth ----------------------------------------------------------------
# Random secret used to sign session tokens. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Full URL of the deployed app (or http://localhost:3000 locally). Required by
# NextAuth for callback URLs even though it's not read directly via process.env
# anywhere in application code.
NEXTAUTH_URL=http://localhost:3000

# --- OAuth providers ---------------------------------------------------------
# Microsoft Entra ID (Azure AD) — used for Microsoft 365 sign-in and Graph access
# (calendar, email, OneDrive/SharePoint, Teams). Register an app at
# https://portal.azure.com under Microsoft Entra ID → App registrations.
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Callback URL: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth — https://github.com/settings/developers
# Callback URL: {NEXTAUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- AI providers --------------------------------------------------------------
# Powers the AI Assistant panel (app/api/assistant) — Claude.
ANTHROPIC_API_KEY=

# Powers the natural-language search bar (app/api/ai-search) — Gemini.
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Vercel system variables (do not set manually) ---------------------------
# VERCEL_ENV, VERCEL_GIT_COMMIT_SHA, VERCEL_GIT_COMMIT_REF, VERCEL_GIT_COMMIT_MESSAGE
# are populated automatically by Vercel at build/runtime and power the developer
# mode panel's build info. Nothing to configure — listed here only for reference.

